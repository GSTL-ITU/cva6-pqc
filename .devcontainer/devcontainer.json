{
  "name": "CVA6 Verification Env",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "mounts": [
    "source=/opt/Xilinx,target=/opt/Xilinx,type=bind,readonly"
  ],
  "runArgs": [
    "--network=host"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "mshr-h.VerilogHDL"
      ]
    }
  },
  "remoteUser": "cva6user",
  "updateRemoteUserUID": true,
  "postCreateCommand": "bash python_requirements.sh"
}